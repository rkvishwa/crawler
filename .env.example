# Site origin only, or full https://host/buildathon/vote (path is stripped).
# In the shell: export VOTE_SMOKE_BASE_URL=https://example.com — no space after =.
# For multi-run or load testing, use staging or localhost—do not point a loop/cron at production.
#
# Examples:
# VOTE_SMOKE_BASE_URL=https://your-staging.example.com
# VOTE_SMOKE_BASE_URL=https://buildathon.cursorsrilanka.com
#
VOTE_SMOKE_BASE_URL=

# Optional: require a 2xx same-origin POST after Confirm (stricter than toast text).
# VOTE_SMOKE_ASSERT_VOTE_POST=1

# Optional: npm run test:smoke:loop — ms between run starts (default 30000 ≈ 2/min).
# VOTE_SMOKE_LOOP_INTERVAL_MS=30000

# Optional: npm run cast-vote — API body slug and bv_token cookie (from browser after visiting vote page).
# VOTE_SLUG=knurdz-metl-faqa
# BV_TOKEN=

# Optional: npm run cast-vote:playwright — default: new random bv_token each run (CAST_VOTE_RANDOM_BV_TOKEN=0 to let server issue only).
# CAST_VOTE_RANDOM_BV_TOKEN=0

# Optional: npm run cast-vote — BV_TOKEN=random or CAST_VOTE_RANDOM_BV_TOKEN=1 for a new UUID per run
# CAST_VOTE_RANDOM_BV_TOKEN=1
